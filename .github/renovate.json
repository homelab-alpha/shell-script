{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", ":semanticCommits", ":rebaseStalePrs"],
  "dependencyDashboard": true,
  "osvVulnerabilityAlerts": true,
  "prConcurrentLimit": 0,
  "prHourlyLimit": 0,
  "timezone": "Europe/Amsterdam",
  "schedule": ["* 9-16 * * 1-7"],
  "rangeStrategy": "bump",
  "ignoreDeps": [],
  "ignorePaths": [],
  "assignees": ["homelab-alpha"],
  "automergeSchedule": ["* 9-16 * * 1-5"],
  "automergeType": "squash",
  "packageRules": [
    {
      "description": "Never automerge major/minor",
      "matchUpdateTypes": ["major", "minor"],
      "automerge": false
    },
    {
      "description": "Automerge patch updates",
      "matchUpdateTypes": ["patch"],
      "automerge": true,
      "platformAutomerge": true
    },
    {
      "description": "Keep Node.js on major version 22",
      "matchPackageNames": ["node", "@types/node"],
      "matchManagers": ["npm", "nodenv", "dockerfile"],
      "allowedVersions": "^22.0.0"
    },
    {
      "description": "Label updates based on type and dependencies",
      "matchUpdateTypes": [
        "major",
        "minor",
        "patch",
        "pin",
        "pinDigest",
        "digest",
        "lockFileMaintenance",
        "rollback",
        "bump",
        "replacement"
      ],
      "addLabels": ["{{{updateType}}}", "{{{depName}}}"]
    },
    {
      "description": "Mark dev dependencies",
      "matchDepTypes": ["devDependencies"],
      "addLabels": ["dev dependencies"]
    }
  ],
  "customManagers": [
    {
      "description": "Track Hugo version in GitHub Actions workflows",
      "customType": "regex",
      "managerFilePatterns": ["/.github/workflows/.*\\.ya?ml$/"],
      "matchStrings": ["HUGO_VERSION:\\s*(?<currentValue>\\d+\\.\\d+\\.\\d+)"],
      "depNameTemplate": "hugo",
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "semver",
      "packageNameTemplate": "gohugoio/hugo"
    }
  ]
}
